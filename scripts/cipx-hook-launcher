#!/usr/bin/env bash
# Locate cipx-hook and exec it. The plugin doesn't ship the binary itself —
# users run /opik:install once (or curl install.sh) to drop cipx into
# ~/.cipx/bin/. This launcher tolerates a missing binary without blocking
# the Claude Code session (spec §4.1 step 3: hook must never fail CC).
#
# Search order:
#   1. cipx-hook on $PATH
#   2. ~/.cipx/bin/cipx-hook
#   3. /usr/local/bin/cipx-hook
#
# On miss: stderr hint + exit 0 so CC keeps running.

set -u

find_bin() {
  if command -v cipx-hook >/dev/null 2>&1; then
    command -v cipx-hook
    return 0
  fi
  for candidate in "$HOME/.cipx/bin/cipx-hook" "/usr/local/bin/cipx-hook"; do
    if [ -x "$candidate" ]; then
      echo "$candidate"
      return 0
    fi
  done
  return 1
}

bin="$(find_bin)" || {
  echo "cipx-hook not found. Run /opik:install (or bash <(curl -fsSL https://raw.githubusercontent.com/comet-ml/cost-intelligence-proxy/main/install.sh)) to install. Tracing is currently disabled." >&2
  exit 0
}

exec "$bin" --quiet "$@"
