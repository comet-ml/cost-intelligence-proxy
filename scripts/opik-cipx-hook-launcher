#!/usr/bin/env bash
# Locate opik-cipx and exec `opik-cipx sync` — the idempotent entry
# point for every CC hook (SessionStart, UserPromptSubmit, StopFailure).
# sync supervises the daemon, brings it up if missing, and points CC's
# ANTHROPIC_BASE_URL at it. The hook event arg passed by CC (if any) is
# ignored: sync is the same operation in every case.
#
# Binaries ship inside the plugin tree at bin/opik-cipx-<os>-<arch>/
# opik-cipx — pushed there by the release workflow in the internal
# source repo — so a clean plugin install already has the right binary
# on disk. PATH / ~/.opik-cipx/bin/ are kept as fallbacks for curl-
# installed setups and dev-time overrides.
#
# Search order:
#   1. ${CLAUDE_PLUGIN_ROOT}/bin/opik-cipx-<os>-<arch>/opik-cipx (plugin-shipped)
#   2. opik-cipx on $PATH
#   3. ~/.opik-cipx/bin/opik-cipx
#   4. /usr/local/bin/opik-cipx
#
# On miss: stderr hint + exit 0 so CC keeps running.

set -u

find_bin() {
  if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
    os="$(uname -s | tr '[:upper:]' '[:lower:]')"
    arch="$(uname -m)"
    case "$arch" in
      x86_64|amd64) arch=amd64 ;;
      arm64|aarch64) arch=arm64 ;;
    esac
    shipped="${CLAUDE_PLUGIN_ROOT}/bin/opik-cipx-${os}-${arch}/opik-cipx"
    if [ -x "$shipped" ]; then
      echo "$shipped"
      return 0
    fi
  fi
  if command -v opik-cipx >/dev/null 2>&1; then
    command -v opik-cipx
    return 0
  fi
  for candidate in "$HOME/.opik-cipx/bin/opik-cipx" "/usr/local/bin/opik-cipx"; do
    if [ -x "$candidate" ]; then
      echo "$candidate"
      return 0
    fi
  done
  return 1
}

bin="$(find_bin)" || {
  echo "opik-cipx not found. Run /opik:install (or bash <(curl -fsSL https://raw.githubusercontent.com/comet-ml/cost-intelligence-proxy/main/install.sh)) to install. Tracing is currently disabled." >&2
  exit 0
}

exec "$bin" sync
